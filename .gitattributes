# Normalize text files to LF to reduce cross-platform merge conflicts
* text=auto eol=lf

# Explicitly normalize common repo files
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.xml text eol=lf

# Treat binary assets as binary
*.tar.gz binary
*.mp3 binary
*.mp4 binary
*.pdf binary
*.docx binary
*.xlsx binary
*.url text eol=crlf
README.md merge=union
course_update.md merge=union
